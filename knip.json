{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "apps/web/src/global.ts",
    "apps/web/src/types/**",
    "next-monorepo/**",
    "packages/database/**",
    "packages/typescript-config/nextjs.json"
  ],
  "ignoreBinaries": ["uv"],
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {},
    "apps/web": {
      "ignoreDependencies": ["webpack"]
    },
    "packages/api": {
      "project": ["src/**/*.ts"]
    },
    "packages/worker": {
      "entry": ["src/runner.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
