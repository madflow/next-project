{
  "$schema": "https://turborepo.dev/schema.json",
  "concurrency": "11",
  "globalEnv": [
    "ANALYSIS_API_KEY",
    "ANALYSIS_API_URL",
    "S3_ACCESS_KEY_ID",
    "S3_BUCKET_NAME",
    "S3_DISABLE_TLS",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_SECRET_ACCESS_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": ["NODE_ENV", "SENTRY_AUTH_TOKEN"]
    },
    "check-translations": {
      "dependsOn": ["^check-translations"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false
    },
    "e2e:api": {
      "cache": false
    },
    "e2e:deps": {
      "cache": false
    },
    "e2e:sign-up-disabled": {
      "cache": false
    },
    "e2e:sign-up-enabled": {
      "cache": false
    },
    "e2e:single": {
      "cache": false
    },
    "env:copy": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "seed": {
      "cache": false,
      "dependsOn": ["db:migrate"]
    },
    "start": {
      "dependsOn": ["^start"]
    },
    "test": {
      "cache": false
    }
  },
  "ui": "stream"
}
