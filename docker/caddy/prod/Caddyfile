{$SITE_ADDRESS} {
	reverse_proxy app:3000 {
		health_uri /api/ready
		health_interval 10s
		health_timeout 5s
		health_fails 2
	}

	encode gzip

	header {
		Strict-Transport-Security max-age=31536000;
		X-Content-Type-Options nosniff
		X-XSS-Protection "1; mode=block"
		X-Frame-Options DENY
		-Server
	}

	log {
		output file /var/log/caddy/access.log
		format console
	}
}
