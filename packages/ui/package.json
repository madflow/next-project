{
  "name": "@repo/ui",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit --emitDeclarationOnly false",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --max-warnings=0 .",
    "postui-add": "prettier src --write --list-different",
    "ui-add": "pnpm dlx shadcn@latest add"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.17",
    "eslint": "^9.39.4",
    "prettier": "3.9.4",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  }
}
