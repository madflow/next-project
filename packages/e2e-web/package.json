{
  "name": "@repo/e2e-web",
  "version": "1.0.0",
  "description": "E2E tests",
  "scripts": {
    "clean": "git clean -xdf .cache dist .turbo node_modules",
    "e2e": "playwright test --project=chromium",
    "e2e:single": "playwright test --project=chromium",
    "e2e:prod": "BASE_URL=http://localhost:3001 playwright test --project=chromium --workers=1",
    "e2e:prod:headed": "BASE_URL=http://localhost:3001 playwright test --project=chromium --workers=1 --headed",
    "e2e:headed": "playwright test --project=chromium --headed --workers=1",
    "e2e:test:chrome": "playwright test --project=chromium",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:webkit": "playwright test --project=webkit",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "e2e:api": "playwright test --project=api",
    "e2e:sign-up-enabled": "playwright test --project=sign-up-enabled",
    "e2e:sign-up-disabled": "playwright test --project=sign-up-disabled",
    "e2e:deps": "playwright install --with-deps",
    "lint": "eslint --max-warnings=0 ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@repo/eslint-config": "workspace:*",
    "@types/node": "^24.11.0",
    "eslint": "^9.39.3",
    "eslint-plugin-playwright": "^2.9.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mailpit-api": "^1.7.2"
  }
}
