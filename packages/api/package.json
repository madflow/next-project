{
  "name": "@repo/api",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/src/client/index.d.ts",
      "default": "./src/client/index.ts"
    },
    "./shared/variableset-transfer": {
      "types": "./dist/src/shared/variableset-transfer.d.ts",
      "default": "./src/shared/variableset-transfer.ts"
    },
    "./server": {
      "types": "./dist/src/server/index.d.ts",
      "default": "./src/server/index.ts"
    },
    "./server/client": {
      "types": "./dist/src/server/client.d.ts",
      "default": "./src/server/client.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "test": "tsx --test src/server/**/*.test.ts",
    "lint": "eslint --max-warnings=0 .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@orpc/client": "^1.14.4",
    "@orpc/contract": "^1.14.4",
    "@orpc/openapi": "^1.14.4",
    "@orpc/openapi-client": "^1.14.4",
    "@orpc/server": "^1.14.4",
    "@orpc/tanstack-query": "^1.14.4",
    "@repo/auth": "workspace:*",
    "@repo/database": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
