    },
    "./server": {
      "types": "./dist/src/server/index.d.ts",
      "default": "./src/server/index.ts"
    },
    "./web/client": {
      "types": "./dist/src/web/client.d.ts",
      "default": "./src/web/client.ts"
    },
    "./web/middleware": {
      "types": "./dist/src/web/middleware.d.ts",
