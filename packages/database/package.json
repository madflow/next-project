{
  "name": "@repo/database",
  "version": "0.0.1",
  "description": "Database package",
  "scripts": {
    "clean": "git clean -xdf .cache dist .turbo node_modules",
    "env:copy": "cp -n .env.dist .env || true",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "db:generate": "drizzle-kit generate",
    "db:generate:custom": "drizzle-kit generate --custom",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check-types": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 ."
  },
  "exports": {
    "./clients": {
      "types": "./src/clients/index.ts",
      "default": "./src/clients/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0"
  }
}
