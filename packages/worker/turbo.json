{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": ["DATABASE_*", "SENTRY_DSN"],
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    },
    "dev": {
      "dependsOn": ["build"],
      "env": ["DATABASE_*"],
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    }
  }
}
