{
  "name": "next-project",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "db:build": "turbo run --filter @repo/database build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "e2e": "turbo run e2e --",
    "e2e:api": "turbo run e2e:api --",
    "e2e:sign-up-enabled": "turbo run e2e:sign-up-enabled --",
    "e2e:sign-up-disabled": "turbo run e2e:sign-up-disabled --",
    "e2e:single": "turbo run e2e:single --",
    "e2e:deps": "turbo run e2e:deps",
    "env:copy": "turbo run env:copy",
    "seed": "turbo run seed",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-translations": "turbo run check-translations",
    "clean": "turbo run clean",
    "knip": "knip"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "knip": "^6.11.0",
    "prettier": "3.8.3",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.8.15",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
