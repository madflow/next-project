{
  "name": "@app/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .cache dist .turbo node_modules",
    "env:copy": "cp -n .env.dist .env || true",
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test src/**/*.test.ts",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix",
    "seed": "tsx --env-file .env ./scripts/seed.ts",
    "check-translations": "tsx ./scripts/check-translations.ts",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
